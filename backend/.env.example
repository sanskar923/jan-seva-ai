# Server
PORT=5000

# Required in production — use a long random string (32+ characters)
JWT_SECRET=replace-with-a-strong-secret-in-production
JWT_EXPIRES_IN=7d

# Comma-separated origins for browser CORS (local + deployed frontend)
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app

# --- Optional free-tier AI (leave blank to use on-device / rule-based fallbacks only) ---

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API key (optional; many accounts include limited free credits)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Hugging Face Inference: https://huggingface.co/settings/tokens
HF_API_KEY=
# Zero-shot text labels (optional)
HF_TEXT_MODEL=facebook/bart-large-mnli
# ImageNet ViT (optional server-side image assist)
HF_IMAGE_MODEL=google/vit-base-patch16-224
